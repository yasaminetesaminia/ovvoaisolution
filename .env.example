# Copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------

NODE_ENV=development

# ---- Database (Supabase Postgres) ----
# Get from: Supabase project → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ---- Supabase Auth ----
# Project Settings → API
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Vapi (voice agent) ----
# vapi.ai → Settings → API Keys
VAPI_API_KEY=
# Set this when you create a webhook secret in Vapi
VAPI_WEBHOOK_SECRET=

# ---- LLM providers ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Voice providers (used inside Vapi config) ----
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ---- Google Calendar OAuth ----
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- WhatsApp Business Cloud API (Meta) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=

# ---- Observability ----
SENTRY_DSN=
POSTHOG_KEY=

# ---- Service URLs ----
API_URL=http://localhost:8787
WEB_URL=http://localhost:3000

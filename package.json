{
  "name": "lavora-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI receptionist platform — multi-tenant Clinic SaaS",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:push": "pnpm --filter @lavora/db db:push",
    "db:migrate": "pnpm --filter @lavora/db db:migrate",
    "db:studio": "pnpm --filter @lavora/db db:studio",
    "db:seed": "pnpm --filter @lavora/db db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
